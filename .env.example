# Brand Settings
BRAND_NAME=MyBrandName
WEBSITE_URL=https://yourwebsite.com

# News Integration Settings (used to fetch current industry trends for AI generation)
NEWS_TOPIC="deutsche Wirtschaft und Tech-Trends"
NEWS_FOCUS="aktuelle Innovationen, Digitalisierung, AI-Trends und Verbrauchertipps"

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Access Control (Restrict bot interaction to yourself)
# Enter either your Telegram User ID (number) OR your Telegram username (without @ symbol)
ADMIN_USER_ID=your_telegram_user_id_here
ADMIN_USERNAME=your_telegram_username_here

# Make.com Webhook URL (used to dispatch published posts to your publishing workflows)
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your_webhook_id_here

# OpenAI API Key (optional, required if you want to generate ideas using GPT models)
OPENAI_API_KEY=sk-your_openai_key_here
